# Wildberries Seller API Credentials
# Получить: https://seller.wildberries.ru/ → Настройки → API токены
# ⚠️ Токены привязаны к категориям: Content, Marketplace, Analytics, Promotion

WB_API_TOKEN=your_wb_api_token_here

# Режим работы (production | mock)
WB_MODE=production

# Переопределение хостов (опционально, для отладки)
# WB_HOST_CONTENT=content-api.wildberries.ru
# WB_HOST_MARKETPLACE=marketplace-api.wildberries.ru
# WB_HOST_PRICES=discounts-prices-api.wildberries.ru
