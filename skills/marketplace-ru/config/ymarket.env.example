# Yandex Market Partner API Credentials
# Получить: https://partner.market.yandex.ru/ → Настройки → API и модули
# ⚠️ Изменения scope токена вступают в силу через ~10 минут
# ⚠️ Макс. 30 токенов на кабинет

YM_API_KEY=your_yandex_market_api_key_here

# ID кабинета (авто-определяется при mp-setup --platform ymarket)
YM_BUSINESS_ID=
# ID магазина
YM_CAMPAIGN_ID=

# Режим работы (production | mock)
YM_MODE=production
