#!/bin/bash
# CLI для управления заказами (мульти-платформа)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(cd "${SCRIPT_DIR}/../lib" && pwd)"

source "${LIB_DIR}/common/platform.sh"

resolve_platform "$@"
set -- "${REMAINING_ARGS[@]}"

source_platform_libs "$CURRENT_PLATFORM" orders

PLATFORM_NAME=$(platform_display_name "$CURRENT_PLATFORM")

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

show_help() {
    cat <<EOF
Использование: mp-orders [--platform ozon|wb|ymarket] <команда> [опции]

Команды:
  list                  Показать новые/активные заказы
  status <order_id>     Показать статус заказа
  stats                 Показать статистику заказов

Опции:
  --platform <name>     Платформа (ozon, wb, ymarket; по умолчанию ozon)
  --mock                Использовать mock данные
  --status <status>     Фильтр по статусу
  --limit <num>         Количество заказов

EOF
}

# Определить правильные функции для платформы
_get_orders() {
    case "$CURRENT_PLATFORM" in
        ozon)    get_orders "$@" ;;
        wb)      wb_get_orders "$@" ;;
        ymarket) ym_get_orders "$@" ;;
    esac
}

_get_order_status() {
    case "$CURRENT_PLATFORM" in
        ozon)    get_order_status "$@" ;;
        wb)      wb_get_order_status "$@" ;;
        ymarket) ym_get_order "$@" ;;
    esac
}

_get_orders_stats() {
    case "$CURRENT_PLATFORM" in
        ozon)    get_orders_stats "$@" ;;
        wb)      wb_get_orders_stats "$@" ;;
        ymarket) ym_get_orders_stats "$@" ;;
    esac
}

_format_orders() {
    case "$CURRENT_PLATFORM" in
        ozon)    format_orders "$1" ;;
        wb)      format_wb_orders "$1" ;;
        ymarket) format_ym_orders "$1" ;;
    esac
}

_format_order_status() {
    case "$CURRENT_PLATFORM" in
        ozon)    format_order_status "$1" ;;
        wb)      format_wb_order_status "$1" ;;
        ymarket) format_ym_order_status "$1" ;;
    esac
}

cmd_list() {
    local args=()
    local is_mock=false

    while [[ $# -gt 0 ]]; do
        args+=("$1")
        [[ "$1" == "--mock" ]] && is_mock=true
        shift
    done

    [[ "$is_mock" == "false" ]] && { load_and_check_credentials || exit 1; }

    echo ""
    echo -e "${BLUE}📦 Заказы ${PLATFORM_NAME}${NC}"
    echo ""

    local orders_json
    orders_json=$(_get_orders "${args[@]}")
    [[ $? -ne 0 ]] && echo -e "${RED}ERROR: Не удалось получить заказы${NC}" >&2 && exit 1

    _format_orders "$orders_json"
    echo ""
}

cmd_status() {
    local order_id=$1; shift
    [[ -z "$order_id" ]] && echo "ERROR: Укажите ID заказа" >&2 && exit 1

    local args=("$order_id")
    local is_mock=false

    while [[ $# -gt 0 ]]; do
        [[ "$1" == "--mock" ]] && is_mock=true
        args+=("$1"); shift
    done

    [[ "$is_mock" == "false" ]] && { load_and_check_credentials || exit 1; }

    echo ""
    echo -e "${BLUE}📋 Статус заказа (${PLATFORM_NAME})${NC}"
    echo ""

    local status_json
    status_json=$(_get_order_status "${args[@]}")
    [[ $? -ne 0 ]] && echo -e "${RED}ERROR: Не удалось получить статус${NC}" >&2 && exit 1

    _format_order_status "$status_json"
    echo ""
}

cmd_stats() {
    local args=()
    local is_mock=false

    while [[ $# -gt 0 ]]; do
        [[ "$1" == "--mock" ]] && is_mock=true
        args+=("$1"); shift
    done

    [[ "$is_mock" == "false" ]] && { load_and_check_credentials || exit 1; }

    echo ""
    echo -e "${BLUE}📊 Статистика заказов (${PLATFORM_NAME})${NC}"
    echo ""

    local stats_json
    stats_json=$(_get_orders_stats "${args[@]}")
    [[ $? -ne 0 ]] && echo -e "${RED}ERROR: Не удалось получить статистику${NC}" >&2 && exit 1

    case "$CURRENT_PLATFORM" in
        ozon)
            local total=$(echo "$stats_json" | jq -r '.total')
            local awaiting=$(echo "$stats_json" | jq -r '.by_status.awaiting_packaging')
            local delivering=$(echo "$stats_json" | jq -r '.by_status.delivering')
            echo "Всего заказов: $total"
            echo "  ⏳ Ожидают сборки: $awaiting"
            echo "  🚚 В доставке: $delivering"
            ;;
        wb)
            local total=$(echo "$stats_json" | jq -r '.total')
            local new_count=$(echo "$stats_json" | jq -r '.by_status.new // 0')
            local confirm=$(echo "$stats_json" | jq -r '.by_status.confirm // 0')
            echo "Всего заказов: $total"
            echo "  🆕 Новые: $new_count"
            echo "  ✅ Подтверждённые: $confirm"
            ;;
        ymarket)
            local total=$(echo "$stats_json" | jq -r '.total')
            local processing=$(echo "$stats_json" | jq -r '.by_status.PROCESSING // 0')
            local delivery=$(echo "$stats_json" | jq -r '.by_status.DELIVERY // 0')
            echo "Всего заказов: $total"
            echo "  📦 В обработке: $processing"
            echo "  🚚 В доставке: $delivery"
            ;;
    esac
    echo ""
}

case "${1:-}" in
    list)    shift; cmd_list "$@" ;;
    status)  shift; cmd_status "$@" ;;
    stats)   shift; cmd_stats "$@" ;;
    -h|--help|help) show_help ;;
    "")      echo "ERROR: Команда не указана" >&2; show_help; exit 1 ;;
    *)       echo "ERROR: Неизвестная команда: $1" >&2; show_help; exit 1 ;;
esac
