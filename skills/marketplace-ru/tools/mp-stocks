#!/bin/bash
# CLI для управления остатками (мульти-платформа)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(cd "${SCRIPT_DIR}/../lib" && pwd)"

source "${LIB_DIR}/common/platform.sh"

resolve_platform "$@"
set -- "${REMAINING_ARGS[@]}"

source_platform_libs "$CURRENT_PLATFORM" stocks

PLATFORM_NAME=$(platform_display_name "$CURRENT_PLATFORM")

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

show_help() {
    cat <<EOF
Использование: mp-stocks [--platform ozon|wb|ymarket] <команда> [опции]

Команды:
  list                         Показать остатки
  list --low                   Только товары с низкими остатками
  get <sku>                    Остаток конкретного товара
  update <sku> <quantity>      Обновить остаток
  rollback <batch-id>          Откатить batch
  rollback --last              Откатить последний batch
  history                      История изменений

Опции:
  --platform <name>            Платформа (ozon, wb, ymarket; по умолчанию ozon)
  --mock                       Mock данные
  --warehouse <id>             ID склада (wb: обязателен для update)
  --threshold <num>            Порог низкого остатка (по умолчанию 10)

EOF
}

_load_creds() { load_and_check_credentials || exit 1; }

_get_stocks() {
    case "$CURRENT_PLATFORM" in
        ozon)    get_stocks "$@" ;;
        wb)      wb_get_stocks "$@" ;;
        ymarket) ym_get_stocks "$@" ;;
    esac
}

_get_stock_by_sku() {
    case "$CURRENT_PLATFORM" in
        ozon)    get_stock_by_sku "$@" ;;
        wb)      wb_get_stock_by_sku "$@" ;;
        ymarket) ym_get_stock_by_sku "$@" ;;
    esac
}

_update_stock() {
    case "$CURRENT_PLATFORM" in
        ozon)    update_stock "$@" ;;
        wb)      wb_update_stocks "$@" ;;
        ymarket) ym_update_stocks "$@" ;;
    esac
}

_format_stocks() {
    local json="$1"
    local show_low="${2:-false}"
    local threshold="${3:-10}"
    case "$CURRENT_PLATFORM" in
        ozon)    format_stocks "$json" "$show_low" ;;
        wb)
            if [[ "$show_low" == "true" ]]; then
                json=$(echo "$json" | jq --argjson t "$threshold" '
                    if .stocks then {stocks: [.stocks[] | select((.amount // .stock // .quantity // 0) < $t)]}
                    else . end')
            fi
            format_wb_stocks "$json"
            ;;
        ymarket)
            if [[ "$show_low" == "true" ]]; then
                json=$(echo "$json" | jq --argjson t "$threshold" '
                    if .warehouses then {warehouses: [.warehouses[] | {warehouseId, offers: [.offers[] | select((.stocks[0].count // 0) < $t)]}]}
                    else . end')
            fi
            format_ym_stocks "$json"
            ;;
    esac
}

cmd_list() {
    local args=()
    local show_low=false
    local is_mock=false
    local threshold=10

    while [[ $# -gt 0 ]]; do
        case $1 in
            --mock) args+=("--mock"); is_mock=true; shift ;;
            --low) show_low=true; shift ;;
            --threshold) threshold="$2"; args+=("$1" "$2"); shift 2 ;;
            --warehouse|--limit) args+=("$1" "$2"); shift 2 ;;
            *) shift ;;
        esac
    done

    [[ "$is_mock" == "false" ]] && _load_creds

    echo ""
    echo -e "${BLUE}📦 Остатки (${PLATFORM_NAME})${NC}"
    echo ""

    local stocks_json
    if [[ "$show_low" == "true" ]] && [[ "$CURRENT_PLATFORM" == "ozon" ]]; then
        stocks_json=$(check_low_stocks "${args[@]}") || { echo -e "${RED}ERROR: Не удалось получить остатки${NC}" >&2; exit 1; }
    else
        stocks_json=$(_get_stocks "${args[@]}") || { echo -e "${RED}ERROR: Не удалось получить остатки${NC}" >&2; exit 1; }
    fi

    _format_stocks "$stocks_json" "$show_low" "$threshold"
    echo ""
}

cmd_get() {
    local sku=$1; shift
    [[ -z "$sku" ]] && echo "ERROR: Укажите SKU" >&2 && exit 1

    local args=("$sku")
    local is_mock=false
    while [[ $# -gt 0 ]]; do
        [[ "$1" == "--mock" ]] && is_mock=true
        args+=("$1"); shift
    done

    [[ "$is_mock" == "false" ]] && _load_creds

    echo ""
    echo -e "${BLUE}📦 Остаток товара (${PLATFORM_NAME})${NC}"
    echo ""

    local stock_data=$(_get_stock_by_sku "${args[@]}")
    [[ -z "$stock_data" ]] && echo "Товар \"$sku\" не найден" && exit 1

    echo "$stock_data" | jq -r '
"SKU: \(.sku // .offerId // .offer_id // "N/A")
📦 Остаток: \(.stock // .amount // .stocks[0].count // .count // 0) шт" +
(if (.stock // .amount // .stocks[0].count // .count // 999) < 10 then "\n⚠️  НИЗКИЙ ОСТАТОК!" else "" end)'
    echo ""
}

cmd_update() {
    local sku=$1
    local new_quantity=$2
    shift 2

    [[ -z "$sku" ]] || [[ -z "$new_quantity" ]] && echo "ERROR: Укажите SKU и количество" >&2 && exit 1

    local is_mock=false
    local auto_confirm=false
    local warehouse_id=""
    local update_args=("$sku" "$new_quantity")

    while [[ $# -gt 0 ]]; do
        case $1 in
            --mock) update_args+=("--mock"); is_mock=true; shift ;;
            --warehouse) warehouse_id="$2"; update_args+=("--warehouse" "$2"); shift 2 ;;
            --yes) auto_confirm=true; shift ;;
            *) shift ;;
        esac
    done

    # WB requires warehouseId
    if [[ "$CURRENT_PLATFORM" == "wb" ]] && [[ -z "$warehouse_id" ]] && [[ "$is_mock" == "false" ]]; then
        echo -e "${YELLOW}⚠️  WB: необходим --warehouse <id>. Получите список: mp-stocks list --platform wb${NC}" >&2
    fi

    # YM: warn about exact SKU matching
    if [[ "$CURRENT_PLATFORM" == "ymarket" ]]; then
        echo -e "${YELLOW}⚠️  Яндекс Маркет: SKU чувствителен к регистру и отступам${NC}"
    fi

    export BATCH_ID=$(audit_generate_batch_id)
    [[ "$is_mock" == "false" ]] && _load_creds

    echo ""
    echo -e "${BLUE}📦 Обновление остатка (${PLATFORM_NAME})${NC}"
    echo ""

    echo "SKU: $sku"
    echo "Новый остаток: $new_quantity шт"
    echo ""

    if [[ "$auto_confirm" == "false" ]]; then
        read -p "Подтвердите обновление (y/N): " confirm
        [[ ! "$confirm" =~ ^[Yy]$ ]] && echo "Отменено" && exit 0
    fi

    echo "🔄 Обновление остатка..."

    update_args+=("--batch-id" "$BATCH_ID")

    local result_json=$(_update_stock "${update_args[@]}")
    local result=$?

    if [[ $result -eq 0 ]]; then
        echo -e "${GREEN}✅ Остаток обновлён!${NC}"
    else
        echo -e "${RED}❌ Ошибка обновления${NC}" >&2
        exit 1
    fi
    echo ""
}

cmd_rollback() {
    local batch_id=""
    local is_mock=false
    local use_last=false
    while [[ $# -gt 0 ]]; do
        case $1 in
            --last) use_last=true; shift ;;
            --mock) is_mock=true; shift ;;
            *) batch_id="$1"; shift ;;
        esac
    done
    if [[ "$use_last" == "true" ]]; then
        batch_id=$(audit_get_last_batch_id "stock_update")
        [[ -z "$batch_id" ]] && echo "ERROR: Нет batch для отката" >&2 && exit 1
    fi
    [[ -z "$batch_id" ]] && echo "ERROR: Укажите batch ID или --last" >&2 && exit 1
    rollback_batch "$batch_id" "stock" "$is_mock" || true
}

cmd_history() { audit_show_history "$@"; }

case "${1:-}" in
    list)     shift; cmd_list "$@" ;;
    get)      shift; cmd_get "$@" ;;
    update)   shift; cmd_update "$@" ;;
    rollback) shift; cmd_rollback "$@" ;;
    history)  shift; cmd_history "$@" ;;
    -h|--help|help) show_help ;;
    "") echo "ERROR: Команда не указана" >&2; show_help; exit 1 ;;
    *)  echo "ERROR: Неизвестная команда: $1" >&2; show_help; exit 1 ;;
esac
