    (14 "Eco1.User" user "User.Eco1")
    (15 "Eco2.User" user "User.Eco2")
    (16 "Edge.Cuts" user)
    (17 "Margin" user)
    (18 "B.CrtYd" user "B.Courtyard")
    (19 "F.CrtYd" user "F.Courtyard")
    (20 "B.Fab" user)
    (21 "F.Fab" user)
  )
  (setup (pad_to_mask_clearance 0) (aux_axis_origin 0 0) (grid_origin 0 0))
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC_3V3")
  (net 3 "VBAT")
  (net 4 "VSYS")
  (net 5 "RS485_A")
  (net 6 "RS485_B")
  (net 7 "SPI1_SCK")
  (net 8 "SPI1_MOSI")
  (net 9 "SPI1_MISO")
  (net 10 "SPI1_CS_FLASH")
  (net 11 "UART1_TX")
  (net 12 "UART1_RX")
  (net 13 "RS485_DE")
  (net 14 "I2C1_SCL")
  (net 15 "I2C1_SDA")
  (net 16 "LED_PWR")
  (net 17 "LED_LORA")
  (net 18 "LED_RS485")
  (net 19 "LED_ERR")
  (net 20 "VBAT_ADC")
  (net 21 "CHG_STAT")
  (net 22 "SWDIO")
  (net 23 "SWCLK")
  (net 24 "NRST")
  (net 25 "RF_ANT")
  (net 26 "SOLAR_VIN")
  (net 27 "VISO")
  (gr_line (start 0 0) (end 100 0) (stroke (width 0.15) (type default)) (layer "Edge.Cuts") (uuid "e01"))
  (gr_line (start 100 0) (end 100 150) (stroke (width 0.15) (type default)) (layer "Edge.Cuts") (uuid "e02"))
  (gr_line (start 100 150) (end 0 150) (stroke (width 0.15) (type default)) (layer "Edge.Cuts") (uuid "e03"))
  (gr_line (start 0 150) (end 0 0) (stroke (width 0.15) (type default)) (layer "Edge.Cuts") (uuid "e04"))
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 5 5) (property "Reference" "MH1") (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask") (tstamp "mh01"))
  )
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 95 5) (property "Reference" "MH2") (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask") (tstamp "mh02"))
  )
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 95 145) (property "Reference" "MH3") (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask") (tstamp "mh03"))
  )
  (footprint "MountingHole:MountingHole_3.2mm_M3" (layer "F.Cu") (at 5 145) (property "Reference" "MH4") (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.2 3.2) (drill 3.2) (layers "*.Cu" "*.Mask") (tstamp "mh04"))
  )
  (gr_text "LoRaWAN Modem LVM-485-SOLAR-01" (at 50 140) (layer "F.SilkS") (effects (font (size 1.5 1.5) (thickness 0.2))) (uuid "txt01"))
  (gr_text "Rev 0.1 | 2026-05-07 | AgroELEMENT" (at 50 145) (layer "F.SilkS") (effects (font (size 1 1) (thickness 0.15))) (uuid "txt02"))
