(kicad_pcb
  (version 20220108)
  (generator "pcbnew")
  (general (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (3 "B.Cu" signal)
    (4 "B.Adhes" user "B.Adhesive")
    (5 "F.Adhes" user "F.Adhesive")
    (6 "B.Paste" user)
    (7 "F.Paste" user)
    (8 "B.SilkS" user "B.Silkscreen")
