{
  "mcpServers": {
    "jlc": {
      "command": "npx",
      "args": [
        "-y",
        "@jlcpcb/mcp@latest"
      ],
      "env": {
        "JLC_CACHE_DIR": "./.cache/jlc",
        "EASYEDA_OUTPUT_DIR": "./libraries"
      }
    },
    "kicad-pcb": {
      "command": "node",
      "args": [
        "/root/.claude-eda/kicad-mcp/dist/index.js"
      ]
    }
  }
}