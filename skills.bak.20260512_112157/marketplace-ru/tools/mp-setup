#!/bin/bash
# Интерактивная настройка API credentials (мульти-платформа)

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$(cd "${SCRIPT_DIR}/../lib" && pwd)"

source "${LIB_DIR}/common/logger.sh"
source "${LIB_DIR}/common/platform.sh"

# Парсинг --platform
resolve_platform "$@"
set -- "${REMAINING_ARGS[@]}"

PLATFORM_NAME=$(platform_display_name "$CURRENT_PLATFORM")

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  🚀 Настройка ${PLATFORM_NAME} API для OpenClaw"
echo "═══════════════════════════════════════════════════════════════"
echo ""

case "$CURRENT_PLATFORM" in
    ozon)
        source "${LIB_DIR}/ozon/auth.sh"
        source "${LIB_DIR}/common/http.sh"
        source "${LIB_DIR}/ozon/http.sh"

        if [[ -f "$CREDENTIALS_FILE" ]]; then
            echo -e "${YELLOW}⚠️  Обнаружена существующая конфигурация${NC}"
            load_credentials
            echo "Client ID: $OZON_CLIENT_ID"
            echo "API Key: ${OZON_API_KEY:0:10}***"
            echo ""
            read -p "Перезаписать? (y/N): " overwrite
            [[ ! "$overwrite" =~ ^[Yy]$ ]] && echo "Отменено" && exit 0
            echo ""
        fi

        echo "📋 Как получить API ключи:"
        echo "1. https://seller.ozon.ru/ → Настройки → API ключи"
        echo "2. Создайте ключ: OpenClaw Integration (права Admin)"
        echo "3. Скопируйте Client-Id и Api-Key"
        echo ""

        while true; do
            read -p "Введите Client ID: " client_id
            [[ -z "$client_id" ]] && echo -e "${RED}ERROR: Не может быть пустым${NC}" && continue
            [[ ! "$client_id" =~ ^[0-9]+$ ]] && echo -e "${RED}ERROR: Должен быть числом${NC}" && continue
            break
        done

        while true; do
            read -s -p "Введите API Key: " api_key; echo
            [[ -z "$api_key" ]] && echo -e "${RED}ERROR: Не может быть пустым${NC}" && continue
            [[ ${#api_key} -lt 10 ]] && echo -e "${RED}ERROR: Слишком короткий${NC}" && continue
            break
        done

        if save_credentials "$client_id" "$api_key"; then
            export OZON_CLIENT_ID="$client_id"
            export OZON_API_KEY="$api_key"
            echo ""
            if test_ozon_connection; then
                echo -e "${GREEN}✅ Настройка завершена!${NC}"
            else
                echo -e "${RED}❌ Credentials сохранены, но подключение не удалось${NC}"
                exit 1
            fi
        fi
        ;;

    wb)
        source "${LIB_DIR}/wb/auth.sh"

        if [[ -f "$WB_CREDENTIALS_FILE" ]]; then
            echo -e "${YELLOW}⚠️  Обнаружена существующая конфигурация WB${NC}"
            load_wb_credentials
            echo "Token: ${WB_API_TOKEN:0:15}***"
            echo ""
            read -p "Перезаписать? (y/N): " overwrite
            [[ ! "$overwrite" =~ ^[Yy]$ ]] && echo "Отменено" && exit 0
            echo ""
        fi

        echo "📋 Как получить API токен Wildberries:"
        echo "1. https://seller.wildberries.ru/ → Настройки → API токены"
        echo "2. Создайте токен с категориями: Marketplace, Content, Analytics"
        echo "   ⚠️  Разные эндпоинты требуют токены разных категорий"
        echo "3. Скопируйте токен"
        echo ""

        while true; do
            read -s -p "Введите API Token: " token; echo
            [[ -z "$token" ]] && echo -e "${RED}ERROR: Не может быть пустым${NC}" && continue
            [[ ${#token} -lt 20 ]] && echo -e "${RED}ERROR: Токен слишком короткий${NC}" && continue
            break
        done

        if save_wb_credentials "$token"; then
            export WB_API_TOKEN="$token"
            source "${LIB_DIR}/common/http.sh"
            source "${LIB_DIR}/wb/http.sh"
            echo ""
            if test_wb_connection; then
                echo -e "${GREEN}✅ Настройка WB завершена!${NC}"
            else
                echo -e "${RED}❌ Credentials сохранены, но подключение не удалось${NC}"
                exit 1
            fi
        fi
        ;;

    ymarket)
        source "${LIB_DIR}/ymarket/auth.sh"

        if [[ -f "$YM_CREDENTIALS_FILE" ]]; then
            echo -e "${YELLOW}⚠️  Обнаружена существующая конфигурация Яндекс Маркет${NC}"
            load_ym_credentials
            echo "API Key: ${YM_API_KEY:0:15}***"
            echo "Business ID: ${YM_BUSINESS_ID:-не установлен}"
            echo "Campaign ID: ${YM_CAMPAIGN_ID:-не установлен}"
            echo ""
            read -p "Перезаписать? (y/N): " overwrite
            [[ ! "$overwrite" =~ ^[Yy]$ ]] && echo "Отменено" && exit 0
            echo ""
        fi

        echo "📋 Как получить API ключ Яндекс Маркет:"
        echo "1. https://partner.market.yandex.ru/ → Настройки → API и модули"
        echo "2. Создайте новый токен (макс. 30 на кабинет)"
        echo "   ⚠️  Изменения прав токена вступают в силу через ~10 минут"
        echo "3. Скопируйте API Key"
        echo ""

        while true; do
            read -s -p "Введите API Key: " api_key; echo
            [[ -z "$api_key" ]] && echo -e "${RED}ERROR: Не может быть пустым${NC}" && continue
            [[ ${#api_key} -lt 10 ]] && echo -e "${RED}ERROR: Слишком короткий${NC}" && continue
            break
        done

        if save_ym_credentials "$api_key"; then
            export YM_API_KEY="$api_key"
            source "${LIB_DIR}/common/http.sh"
            source "${LIB_DIR}/ymarket/http.sh"
            echo ""
            echo "🔄 Проверка подключения и получение ID..."
            if test_ym_connection; then
                echo -e "${GREEN}✅ Настройка Яндекс Маркет завершена!${NC}"
            else
                echo -e "${RED}❌ Credentials сохранены, но подключение не удалось${NC}"
                exit 1
            fi
        fi
        ;;
esac

echo ""
echo "Доступные команды:"
echo "  mp-test --platform $CURRENT_PLATFORM          - проверить подключение"
echo "  mp-orders list --platform $CURRENT_PLATFORM    - показать заказы"
echo "  mp-prices list --platform $CURRENT_PLATFORM    - показать цены"
echo "  mp-stocks list --platform $CURRENT_PLATFORM    - показать остатки"
echo ""
